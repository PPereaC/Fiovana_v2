{
  "applications": {
    "Fiovana_v2.Web.Public": {
      "type": "dotnet-project",
      "launchUrl": "https://localhost:44375",
      "path": "../../../src/Fiovana_v2.Web.Public/Fiovana_v2.Web.Public.csproj",
      "kubernetesService": ".*-webpublic$",
      "healthCheckEndpoint": "/health-status",
      "healthUiEndpoint": "/health-ui",
      "execution": {
        "order": 1
      }
    },
    "Fiovana_v2.HttpApi.Host": {
      "type": "dotnet-project",
      "launchUrl": "https://localhost:44388",
      "path": "../../../src/Fiovana_v2.HttpApi.Host/Fiovana_v2.HttpApi.Host.csproj",
      "kubernetesService": ".*-httpapihost$",
      "healthCheckEndpoint": "/health-status",
      "healthUiEndpoint": "/health-ui",
      "execution": {
        "order": 4
      }
    },
    "Fiovana_v2.Angular": {
      "type": "cli",
      "workingDirectory": "../../../angular",
      "startCommand": "./start.ps1",
      "launchUrl": "http://localhost:4200",
      "kubernetesService": ".*-angular$",
      "execution": {
        "order": 2
      }    
    }
  },
  "containers": {
    "serviceName": "Fiovana_v2-Containers",
    "files": {
      "../../docker/containers/redis.yml": {
      },
      "../../docker/containers/rabbitmq.yml": {
      }
          }
  },
  "tasks":{
    "Initialize Solution":{
      "behaviour": 2,
      "startCommand": "./initialize-solution.ps1",
      "workingDirectory": "../../scripts",
      "shortDescription": "Installs required UI libraries, creates required certificates and seeds the database."
    },
    "Migrate Database":{
      "behaviour": 0,
      "startCommand": "./migrate-database.ps1",
      "workingDirectory": "../../scripts",
      "shortDescription": "Migrates the database to the latest version."
    }
  }
}
